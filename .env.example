# ─── Telegram ────────────────────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
ADMINS=123456789,987654321          # comma-separated super-admin telegram IDs

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Security ────────────────────────────────────────────────────────────────
API_SECRET=aislide_secret_2026      # shared secret between Next.js ↔ FastAPI
JWT_SECRET=change_me_random_64chars # JWT signing key

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=aislide_pg_2026
# These are auto-constructed in docker-compose from POSTGRES_PASSWORD:
# DATABASE_URL=postgresql+asyncpg://aislide:<pw>@postgres:5432/aislide
# DATABASE_URL_SYNC=postgresql://aislide:<pw>@postgres:5432/aislide

# ─── Redis ───────────────────────────────────────────────────────────────────
# REDIS_URL is auto-set in docker-compose: redis://redis:6379/0

# ─── Cloudflare R2 (optional — files delivered via Telegram if not set) ──────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=aislide
R2_PUBLIC_URL=                      # e.g. https://cdn.aislide.uz

# ─── Pixabay (optional — for image embedding in PPTX) ────────────────────────
PIXABAY_API_KEY=

# ─── Legacy ──────────────────────────────────────────────────────────────────
ip=localhost                        # kept for bot compatibility
PRESENTON_URL=http://presenton:80   # set in docker-compose automatically
